# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

# Local docker-compose env overrides
.env

# Deployed exploded NRG webapp (served by Tomcat). The classes and bundled
# jars under WEB-INF/ are tracked so dependency upgrades show up as diffs;
# the *.class / *.jar rules above would otherwise hide them.
!wattos/NRG/**/*.class
!wattos/NRG/WEB-INF/lib/*.jar
